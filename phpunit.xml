<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <!-- Granular suites: run individually when memory is tight.
             Usage: php artisan test -testsuite=Commission
             Usage: php artisan test -testsuite=Abc,Statistics -->
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Abc">
            <directory>tests/Feature/Abc</directory>
        </testsuite>
        <testsuite name="Commission">
            <directory>tests/Feature/Commission</directory>
        </testsuite>
        <testsuite name="Statistics">
            <directory>tests/Feature/Statistics</directory>
        </testsuite>
        <testsuite name="Inventory">
            <directory>tests/Feature/Inventory</directory>
        </testsuite>
        <testsuite name="Auth">
            <directory>tests/Feature/Auth</directory>
        </testsuite>
        <testsuite name="Core">
            <directory>tests/Feature/CarLoad</directory>
            <directory>tests/Feature/Product</directory>
            <directory>tests/Feature/VenteStats</directory>
            <directory>tests/Feature/Dashboard</directory>
            <directory>tests/Feature/DeliveryCost</directory>
            <directory>tests/Feature/ActivityReport</directory>
            <directory>tests/Feature/PurchaseInvoice</directory>
            <directory>tests/Feature/SalesInvoice</directory>
            <directory>tests/Feature/SalespersonApi</directory>
            <file>tests/Feature/PurchaseInvoicePutInStockTest.php</file>
            <file>tests/Feature/PurchaseInvoiceTransportationCostDistributionTest.php</file>
            <file>tests/Feature/CarLoadStockValueTest.php</file>
            <file>tests/Feature/CarLoadTransformToVariantsTest.php</file>
            <file>tests/Feature/ProfileTest.php</file>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <ini name="memory_limit" value="512M"/>
        <env name="APP_ENV" value="testing"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_DRIVER" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>
